<Window x:Class="PVPlus2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PVPlus2"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:views="clr-namespace:PVPlus2.Views"
        Title="MainWindow" Height="450" Width="800">
    <hc:TabControl IsTabFillEnabled="False" TabItemWidth="120">
        <hc:TabItem Header="MainPV" IsSelected="True">
            <views:MainPVView />
        </hc:TabItem>
        <hc:TabItem Header="Sample">
            <views:SampleView />
        </hc:TabItem>
        <hc:TabItem Header="LTFHelper">
            <views:LTFHelperView />
        </hc:TabItem>
        <hc:TabItem Header="TabTest">
            <views:TestView />
        </hc:TabItem>
    </hc:TabControl>
</Window>
